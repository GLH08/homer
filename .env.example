# ============================================
# Homer 环境变量配置
# ============================================
#
# 使用方式：
# 1. 复制此文件为 .env
# 2. 填写实际值
# 3. .env 文件已在 .gitignore 中，不会推送到 GitHub
#

# ===== 天气 API =====
OPENWEATHER_API_KEY=

# ===== Emby / Jellyfin =====
EMBY_API_KEY=

# ===== Plex =====
PLEX_TOKEN=

# ===== Tautulli =====
TAUTULLI_API_KEY=

# ===== Sonarr / Radarr =====
SONARR_API_KEY=
RADARR_API_KEY=

# ===== Glances =====
GLANCES_URL=http://localhost:61208

# ===== Pi-hole =====
PIHOLE_API_KEY=

# ===== Portainer =====
PORTAINER_API_KEY=

# ===== Proxmox =====
PROXMOX_API_TOKEN=

# ===== FreshRSS =====
FRESHRSS_USER=
FRESHRSS_PASS=

# ===== Miniflux =====
MINIFLUX_API_KEY=

# ===== Immich =====
IMMICH_API_KEY=

# ===== Home Assistant =====
HA_API_KEY=

# ===== OpenHAB =====
OPENHAB_API_KEY=
